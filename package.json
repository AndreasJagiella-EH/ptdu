{
  "name": "ptdu",
  "version": "1.0.0",
  "description": "CLI tool to update transitive dependencies in pnpm projects to resolve vulnerabilities",
  "type": "module",
  "bin": {
    "ptdu": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "pnpm",
    "dependencies",
    "vulnerability",
    "transitive",
    "update",
    "override"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "semver": "^7.7.4",
    "yaml": "^2.8.2"
  }
}
